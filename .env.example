# Config
PORT=3001
PORT_DATABASE=5432

# Postgres
PG_USER="postgres"
PG_PASSWORD="postgres"
PG_DATABASE_NAME="nest-bp-db"

# JWT 
JWT_ACCESS_TOKEN_SECRET="abc"
JWT_REFRESH_TOKEN_SECRET="cba"
JWT_FORGOT_PASSWORD_SECRET="def"

DATABASE_URL="postgresql://${PG_USER}:${PG_PASSWORD}@db:${PORT_DATABASE}/${PG_DATABASE_NAME}?schema=public"

# Rate limiting (ThrottlerModule)
THROTTLE_TTL=60000    # Time window in milliseconds
THROTTLE_LIMIT=100    # Max requests per window for general routes

# CORS — comma-separated list of allowed origins
# Leave unset to disable CORS entirely (e.g. for internal/private APIs)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

